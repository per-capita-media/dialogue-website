# ─── Supabase ────────────────────────────────────────────────────────────────
# SvelteKit requires the PUBLIC_ prefix (NOT NEXT_PUBLIC_) for env vars that
# are exposed to the browser. The values are identical — just rename.
#
# If your Supabase project uses the NEW key naming:
#   "publishable key" (sb_publishable_…)  →  use as PUBLIC_SUPABASE_ANON_KEY
#   "secret key"      (sb_secret_…)       →  use as SUPABASE_SERVICE_ROLE_KEY
#
# If your Supabase project uses the OLDER naming, the values map 1:1:
#   "anon key"            →  PUBLIC_SUPABASE_ANON_KEY
#   "service_role key"    →  SUPABASE_SERVICE_ROLE_KEY

# Public — exposed to the browser via SvelteKit `$env/static/public`
PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx_or_anon_jwt_here

# Private — server-only. Used for: create-admin script, audit log writes,
# Storage uploads, and a small number of one-way state transitions documented
# at the call sites. Find it in Supabase dashboard → Project Settings → API.
# DO NOT prefix with PUBLIC_ — that would leak it to the browser.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx_or_service_role_jwt_here

# ─── Email (Resend) — optional but required for in-app email invitations ──
# If both of these are set, the admin "Invitations" page will email the
# signup link automatically. If they're missing, the admin can still create
# the invitation and copy/share the URL by hand.
#
#   1. Sign up at https://resend.com (free tier covers MVP volumes).
#   2. Verify your sending domain — OR for development you can use the
#      pre-verified test address `onboarding@resend.dev` (only sends to the
#      account owner's verified email; fine for testing salhananusha@gmail.com).
#   3. Create an API key and paste it below.
RESEND_API_KEY=
MAIL_FROM="Dialogue Invitations <onboarding@resend.dev>"

# Public site URL used in the create-admin / add-staff scripts to print the
# right sign-in link after creating users. Optional.
PUBLIC_SITE_URL=http://localhost:5173
